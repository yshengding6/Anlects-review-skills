          "变量替换实验",
          "证据分级综述",
          "老丁因子",
          "冷知识命题"
        ],
        "not_applicable": [],
        "optional": ["圆桌会议纪要"]
      },
      "expected_laoding_factor": {
        "must_have": [
          "核心判断",
          "证据链",
          "论证路径",
          "潜在反例",
          "与主流解释的分歧点",
          "定位说明"
