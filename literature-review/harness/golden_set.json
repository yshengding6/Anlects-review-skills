        "sample_core_judgment": "八佾章不是在讲忍不忍的问题，而是在讲礼制作为权力标识的功能——谁在用天子的规格跳舞，谁就在宣示权力的归属。"
      },
      "evidence_grading_check": {
        "must_contain_tags": ["[实证]", "[推论]", "[缺失]"],
        "no_untagged_inferences": true
      },
      "terminology_consistency_check": {
        "terms_to_check": ["季氏", "三桓", "八佾"],
        "must_be_consistent": true
      }
