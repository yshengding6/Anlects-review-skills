    {
      "id": "qixi_chapter",
      "name": "乞醯章——六维解剖+变量替换+异常检测",
      "input": {
        "topic": "《论语·公冶长》'孰谓微生高直？或乞醯焉，乞诸其邻而与之。'",
        "text": "孰谓微生高直？或乞醯焉，乞诸其邻而与之。",
        "context": "此章讨论'直'的内涵，乞醯行为是否构成'不直'",
        "provided_commentaries": [
          "孔安国注：乞之四邻，以应求者，用意委曲，非为直人。",
          "朱熹《四书章句集注》：微生姓，高名，鲁人。乞醯非直，而托乞以与人，尤为不直。"
        ]
      },
      "expected_routes": {
        "political_history": false,
        "reason_political": "文本不涉及政治史关键词（三桓/季氏/公室等）",
