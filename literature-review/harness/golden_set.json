{
  "description": "Anlects Review Skill v5.0.0 - Golden Set for Harness Testing",
  "version": "5.0.0",
  "created": "2026-04-14",
  "principle_zero_rules": {
    "route_triggers": {
      "political_history": {
        "keywords": ["三桓", "季氏", "公室", "君臣", "礼制", "僭越", "权臣", "去国", "流亡"],
        "blade": "政治史探针"
      },
      "anomaly_detection": {
        "keywords": ["异文", "脱文", "衍文", "错简", "版本差异"],
        "condition": "原文已被历代注家多角度解读",
        "blade": "异常检测"
      },
      "variable_replacement": {
        "condition": "原文概念存在换词后语义崩塌的空间",
        "blade": "变量替换实验"
      },
      "six_dimension": {
        "condition": "用户提供了注疏原文",
        "blade": "六维解剖"
      }
    },
    "execution_order": [
      "字词校释",
      "政治史还原",
      "六维解剖",
      "异常检测",
      "变量替换",
      "圆桌会议",
      "综述"
    ],
    "output_chapters": [
      {"id": 1, "name": "原子化扫描结果", "always": true},
      {"id": 2, "name": "政治史还原", "route": "political_history"},
      {"id": 3, "name": "注疏六维解剖", "route": "six_dimension"},
      {"id": 4, "name": "异常检测报告", "route": "anomaly_detection"},
      {"id": 5, "name": "变量替换实验", "route": "variable_replacement"},
      {"id": 6, "name": "圆桌会议纪要", "condition": "需要圆桌论辩时"},
      {"id": 7, "name": "证据分级综述", "always": true},
      {"id": 8, "name": "老丁因子", "always": true},
      {"id": 9, "name": "冷知识命题", "required": false}
    ],
    "laoding_factor_structure": [
      "核心判断",
      "证据链",
      "论证路径",
      "潜在反例",
      "与主流解释的分歧点",
      "定位说明"
    ]
  },
  "cases": [
