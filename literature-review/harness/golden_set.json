        "text": "孔子谓季氏：八佾舞于庭，是可忍也，孰不可忍也？",
        "context": "此章涉及季氏僭越礼制、三桓专权的政治背景",
        "provided_commentaries": [
          "朱熹《四书章句集注》：季氏，鲁大夫季孙氏也。八佾，天子之舞也。季氏以大夫而僭天子之舞，是以可忍为不可忍也。"
        ]
      },
      "expected_routes": {
        "political_history": true,
        "reason_political": "文本涉及'季氏'、'僭越'、礼制等政治史关键词",
        "anomaly_detection": true,
        "reason_anomaly": "历代注家对'忍'字有多角度解读（忍心/容忍）",
        "variable_replacement": true,
        "reason_variable": "'忍'字替换为'容'/'恕'后语义是否崩塌可验证",
        "six_dimension": true,
        "reason_six_dimension": "用户提供了朱熹注疏原文"
      },
      "expected_chapters": {
        "present": [
          "原子化扫描结果",
          "政治史还原",
          "注疏六维解剖",
